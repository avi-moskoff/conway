[Unit]
Description=Conway Game of Life LED Matrix
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/avi/conway
ExecStart=/home/avi/conway/run.sh

Restart=on-failure
RestartSec=2

# Give the matrix driver high priority
Nice=-20

# Forward stdout/stderr to the journal
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
